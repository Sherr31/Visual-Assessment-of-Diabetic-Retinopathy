# Copy to `.env` and edit: cp .env.example .env

SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# MongoDB
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/vadr_db?retryWrites=true&w=majority

# JWT / session
VADR_ACCESS_TOKEN_EXPIRES_MIN=15
VADR_REFRESH_TOKEN_EXPIRES_DAYS=7
VADR_REFRESH_COOKIE_NAME=vadr_refresh_token
VADR_REFRESH_COOKIE_SECURE=false
VADR_REFRESH_COOKIE_SAMESITE=Lax

# Registration OTP
VADR_REG_CODE_EXPIRES_MIN=10
VADR_REG_RESEND_MAX_PER_HOUR=3
VADR_REG_MAX_VERIFY_FAILS=8
VADR_REJECTION_REAPPLY_DAYS=30

# CORS (comma-separated origins; credentials enabled for refresh cookie)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting (optional Redis; falls back to in-memory if unset)
# REDIS_URL=redis://localhost:6379/0

# Demo seed password
VADR_DEMO_PASSWORD=admin123

# ── Brevo SMTP (transactional / verification emails) ──
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=VADR <noreply@yourdomain.com>

# Local dev without sending mail: print 6-digit code in Flask terminal
# VADR_LOG_EMAIL_CODE=1
