# Copy to `.env` and edit. cp .env.example .env

SECRET_KEY=change-me-in-production

# Optional: overrides default in app.py
# MONGO_URI=mongodb+srv://...

# ── Brevo SMTP (transactional / verification emails) ──
# Dashboard: https://app.brevo.com → SMTP & API → SMTP
# Use the SMTP key as password (not your Brevo login password).
# MAIL_DEFAULT_SENDER must be a verified sender/domain in Brevo.

MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
# If you see "timed out" on 587, the app retries 2525 automatically. Or set:
# MAIL_PORT=2525
MAIL_USE_TLS=true
# MAIL_SMTP_TIMEOUT=45
# MAIL_SMTP_TRY_FALLBACK=false   # set to disable 587↔2525 retry
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=VADR <noreply@yourdomain.com>

# Same keys work if you prefer SMTP_* names:
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_USER=your-smtp-login-email
# SMTP_PASSWORD=your-smtp-key
# SMTP_FROM=VADR <noreply@yourdomain.com>

# If port 587 is blocked, try MAIL_PORT=2525 (still use MAIL_USE_TLS=true).

# Local dev without sending mail: print 6-digit code in Flask terminal
# VADR_LOG_EMAIL_CODE=1

# VADR_REG_CODE_EXPIRES_MIN=30
# VADR_REG_RESEND_COOLDOWN_SEC=60
